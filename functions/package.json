{
  "name": "functions",
  "version": "0.0.1",
  "private": true,
  "description": "Cloud Functions for Vacaciones",
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "prebuild": "node scripts/copy-shared.js",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.0.1",
    "google-auth-library": "^9.14.1",
    "googleapis": "^144.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.5.4"
  }
}
