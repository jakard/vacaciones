{
  "hosting": {
    "public": "app",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/api/initUser", "function": { "functionId": "initUser", "region": "us-central1" } },
      { "source": "/api/createTeam", "function": { "functionId": "createTeam", "region": "us-central1" } },
      { "source": "/api/joinTeam", "function": { "functionId": "joinTeam", "region": "us-central1" } },
      { "source": "/api/createCoverageRequest", "function": { "functionId": "createCoverageRequest", "region": "us-central1" } },
      { "source": "/api/acceptCoverageRequest", "function": { "functionId": "acceptCoverageRequest", "region": "us-central1" } },
      { "source": "/api/getLeaderboard", "function": { "functionId": "getLeaderboard", "region": "us-central1" } },
      { "source": "/api/sendScroll", "function": { "functionId": "sendScroll", "region": "us-central1" } },
      { "source": "/api/setProfile", "function": { "functionId": "setProfile", "region": "us-central1" } },
      { "source": "/api/cancelBounty", "function": { "functionId": "cancelBounty", "region": "us-central1" } },
      { "source": "/api/updateTeam", "function": { "functionId": "updateTeam", "region": "us-central1" } },
      { "source": "/api/updateCrewSettings", "function": { "functionId": "updateCrewSettings", "region": "us-central1" } },
      { "source": "/api/getCrewSettings", "function": { "functionId": "getCrewSettings", "region": "us-central1" } },
      { "source": "/api/topUpOnboardingGrant", "function": { "functionId": "topUpOnboardingGrant", "region": "us-central1" } },
      { "source": "/api/getCrewMembers", "function": { "functionId": "getCrewMembers", "region": "us-central1" } },
      { "source": "/api/reactToScroll", "function": { "functionId": "reactToScroll", "region": "us-central1" } },
      { "source": "/api/updateBountyDetails", "function": { "functionId": "updateBountyDetails", "region": "us-central1" } },
      { "source": "/api/generateBriefing", "function": { "functionId": "generateBriefing", "region": "us-central1" } },
      { "source": "/api/updateMemberRole", "function": { "functionId": "updateMemberRole", "region": "us-central1" } },
      { "source": "/api/removeMember", "function": { "functionId": "removeMember", "region": "us-central1" } },
      { "source": "/api/grantBonusDoubloons", "function": { "functionId": "grantBonusDoubloons", "region": "us-central1" } },
      { "source": "/api/forceCompleteBounty", "function": { "functionId": "forceCompleteBounty", "region": "us-central1" } },
      { "source": "/api/getAuditLog", "function": { "functionId": "getAuditLog", "region": "us-central1" } },
      { "source": "/api/createInviteToken", "function": { "functionId": "createInviteToken", "region": "us-central1" } },
      { "source": "/api/exportMyData", "function": { "functionId": "exportMyData", "region": "us-central1" } },
      { "source": "/api/deleteMyAccount", "function": { "functionId": "deleteMyAccount", "region": "us-central1" } },
      { "source": "/api/disbandCrew", "function": { "functionId": "disbandCrew", "region": "us-central1" } },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "/**",
        "headers": [
          { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=(), payment=(), usb=()" },
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
          { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://apis.google.com https://*.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://*.cloudfunctions.net https://*.run.app wss://*.firebaseio.com https://accounts.google.com https://identitytoolkit.googleapis.com https://www.googleapis.com https://oauth2.googleapis.com https://generativelanguage.googleapis.com; frame-src 'self' https://*.firebaseapp.com https://accounts.google.com; object-src 'none'; base-uri 'self'; form-action 'self'" }
        ]
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ],
      "runtime": "nodejs22"
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "singleProjectMode": true
  }
}
